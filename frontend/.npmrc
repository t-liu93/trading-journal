# Some devDependencies (openapi-typescript@7.13 as of 2026-05) still declare
# `typescript ^5.x` in their peerDependencies, but our project is on
# typescript 6. The mismatch is cosmetic — the affected tools use TS's
# emit / compiler APIs which are stable across 5 → 6 — but `npm install`
# refuses to resolve without an explicit opt-out. Setting this here keeps
# clean installs working for everyone until the upstream peer ranges catch up.
legacy-peer-deps=true
