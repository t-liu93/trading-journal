# Copy this file to .env and fill in real values for local development.
# `.env` is gitignored; `.env.example` is committed as a template.

# --- Database (used from Phase 2 onwards) ---
# Async SQLAlchemy URL. SQLite is the default for dev.
# For Postgres later: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# --- Auth (used from Phase 3 onwards) ---
# Used to sign FastAPI Users cookies / tokens.
# Generate a real secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
COOKIE_SECRET=replace-me-before-running-anywhere-real

# Cookie / session config
COOKIE_NAME=trading_journal_session
# COOKIE_SECURE MUST be true once you're behind HTTPS.
COOKIE_SECURE=false
# Session lifetime in seconds (default 7 days).
SESSION_LIFETIME_SECONDS=604800
# Minimum password length enforced on registration.
MIN_PASSWORD_LENGTH=8

# --- Behaviour ---
# Enables FastAPI debug mode, more verbose logging, etc.
DEBUG=true
