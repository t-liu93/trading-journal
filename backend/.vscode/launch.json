    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app:app",
                "--host=0.0.0.0",
                "--reload",
                "--port=18881"
            ],
            "jinja": true,
            "autoStartBrowser": false,
            "env": {
                "CONFIG_FILE": "devsettings.yaml"
            },
            "console": "integratedTerminal"
        }
    ]
}